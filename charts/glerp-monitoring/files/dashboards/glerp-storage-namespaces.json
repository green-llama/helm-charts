        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#9BE198"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
