    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 10,
      "title": "Top Namespaces by Longhorn Usage",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineWidth": 1
          },
          "mappings": [],
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {
                "color": "#27B093",
                "value": null
              },
              {
                "color": "#f0d349",
                "value": 70
              },
              {
                "color": "#e04b4b",
                "value": 85
              }
            ]
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#D1E0D7"
                }
              },
              {
                "id": "displayName",
                "value": "Provisioned"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 11,
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 200
      },
      "title": "Longhorn Actual Usage by Namespace (Top 20)",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(20, glerp:longhorn_namespace_usage_bytes)",
          "instant": true,
          "legendFormat": "{{ claimnamespace }} (Used)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(20, glerp:longhorn_namespace_provisioned_bytes)",
          "instant": true,
          "legendFormat": "{{ claimnamespace }} (Provisioned)",
          "refId": "B"
        }
      ],
      "description": "Actual bytes consumed by Longhorn volumes per namespace. The green bar shows actual disk usage; the gray bar shows provisioned (requested) capacity.\n\n**Why actual usage can exceed provisioned:** Longhorn stores multiple replicas of each volume (default 3\u00d7). The actual bytes on disk = logical data \u00d7 replica count + snapshot overhead. A volume provisioned at 10 GiB with 3 replicas will consume ~30 GiB of raw node storage. Additionally, Longhorn snapshots grow over time as data changes. Provisioned capacity reflects what Kubernetes sees; actual usage reflects real disk consumption."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 30,
      "title": "Storage Distribution",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "mappings": [],
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "id": 31,
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "title": "Longhorn Usage by Namespace",
      "type": "piechart",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "glerp:longhorn_namespace_usage_bytes > 0",
          "instant": true,
          "legendFormat": "{{ claimnamespace }}"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "mappings": [],
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "id": 32,
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "title": "MinIO Usage by Namespace",
      "type": "piechart",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (namespace)(minio_cluster_usage_total_bytes) > 0",
          "instant": true,
          "legendFormat": "{{ namespace }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 40,
      "title": "Storage Utilization Over Time",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "bytes",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "id": 41,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Longhorn Usage Over Time by Namespace",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "glerp:longhorn_namespace_usage_bytes > 0",
          "legendFormat": "{{ claimnamespace }}"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "bytes",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "id": 42,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "MinIO Usage Over Time by Namespace",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (namespace)(minio_cluster_usage_total_bytes) > 0",
          "legendFormat": "{{ namespace }}"
        }
      ]
    },
    {
      "collapsed": false,
      "description": "Per-drive DirectPV storage breakdown for the selected namespace. Select a namespace above to filter to that tenant's drives.",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "id": 50,
      "title": "DirectPV Storage \u2014 $namespace",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "DirectPV drives allocated to PVCs in the selected namespace. Each row is one physical drive on one node. Use this view to identify which node needs capacity added.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#27B093",
                "value": null
              }
            ]
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "% Used"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "#27B093",
                      "value": null
                    },
                    {
                      "color": "#f5a623",
                      "value": 70
                    },
                    {
                      "color": "#e02f44",
                      "value": 85
                    }
                  ]
                }
              },
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "max",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(Capacity|Used|Free)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "id": 51,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "% Used",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "directpv_stats_bytes_total * on(volumeID) group_left(persistentvolumeclaim, namespace) label_replace(kube_persistentvolumeclaim_info{storageclass=\"directpv-min-io\", namespace=\"$namespace\"}, \"volumeID\", \"$1\", \"volumename\", \"(.+)\")",
          "legendFormat": "{{node}} | {{persistentvolumeclaim}}",
          "instant": true,
          "format": "table",
          "refId": "Allocated"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "directpv_stats_bytes_used * on(volumeID) group_left(persistentvolumeclaim, namespace) label_replace(kube_persistentvolumeclaim_info{storageclass=\"directpv-min-io\", namespace=\"$namespace\"}, \"volumeID\", \"$1\", \"volumename\", \"(.+)\")",
          "legendFormat": "{{node}} | {{persistentvolumeclaim}}",
          "instant": true,
          "format": "table",
          "refId": "Used"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "(directpv_stats_bytes_total - directpv_stats_bytes_used) * on(volumeID) group_left(persistentvolumeclaim, namespace) label_replace(kube_persistentvolumeclaim_info{storageclass=\"directpv-min-io\", namespace=\"$namespace\"}, \"volumeID\", \"$1\", \"volumename\", \"(.+)\")",
          "legendFormat": "{{node}} | {{persistentvolumeclaim}}",
          "instant": true,
          "format": "table",
          "refId": "Free"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "directpv_stats_bytes_used / directpv_stats_bytes_total * 100 * on(volumeID) group_left(persistentvolumeclaim, namespace) label_replace(kube_persistentvolumeclaim_info{storageclass=\"directpv-min-io\", namespace=\"$namespace\"}, \"volumeID\", \"$1\", \"volumename\", \"(.+)\")",
          "legendFormat": "{{node}} | {{persistentvolumeclaim}}",
          "instant": true,
          "format": "table",
          "refId": "PctUsed"
        }
      ],
      "title": "DirectPV PVC Breakdown \u2014 $namespace",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "node": "Node",
              "persistentvolumeclaim": "PVC",
              "Value #Allocated": "Allocated",
              "Value #Used": "Used",
              "Value #Free": "Free",
              "Value #PctUsed": "% Used"
            },
            "excludeByName": {
              "Time": true,
              "job": true,
              "__name__": true,
              "instance": true,
              "container": true,
              "endpoint": true,
              "namespace": true,
              "pod": true,
              "service": true,
              "volumeID": true,
              "exported_node": true
            },
            "indexByName": {
              "Node": 0,
              "PVC": 1,
              "Allocated": 2,
              "Used": 3,
              "Free": 4,
              "% Used": 5
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": [
    "glerp",
    "storage",
    "namespaces"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(minio_cluster_usage_total_bytes, namespace)",
        "hide": 0,
        "includeAll": false,
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(minio_cluster_usage_total_bytes, namespace)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "GLerp Storage \u2014 Namespace Breakdown",
  "uid": "glerp-storage-namespaces",
  "version": 1
}
