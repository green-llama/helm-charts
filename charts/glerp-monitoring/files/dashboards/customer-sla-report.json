{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "#1F60C4",
        "limit": 100,
        "name": "Maintenance Windows",
        "showIn": 0,
        "tags": ["maintenance"],
        "type": "tags"
      }
    ]
  },
  "description": "Per-site SLA report for customer sharing. Select the site, set the reporting period, then share via Public Dashboard link or export as PDF.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Internal: Uptime Overview", "url": "/d/glerp-uptime-overview", "type": "link", "icon": "external link", "targetBlank": false }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "SLA Summary — $site",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Uptime percentage over the selected reporting period using the login-page content probe.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 3,
          "min": 95,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 98.0 },
              { "color": "green",  "value": 99.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Uptime",
      "type": "stat",
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"glerp-sites-login\", site=\"$site\"}[$__range]) * 100",
          "legendFormat": "Uptime %",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Whether the site met the 99.5% monthly SLA target over the selected period.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 99.5 }
            ]
          },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 99.5,
                "to": 100,
                "result": { "text": "COMPLIANT", "color": "green", "index": 0 }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 99.4999,
                "result": { "text": "BREACH", "color": "red", "index": 1 }
              }
            }
          ]
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "SLA Status (99.5% target)",
      "type": "stat",
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"glerp-sites-login\", site=\"$site\"}[$__range]) * 100",
          "legendFormat": "Status",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total downtime in minutes over the selected reporting period.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red",    "value": 216 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Downtime (minutes)",
      "type": "stat",
      "targets": [
        {
          "expr": "(1 - avg_over_time(probe_success{job=\"glerp-sites-login\", site=\"$site\"}[$__range])) * $__range_s / 60",
          "legendFormat": "Downtime (min)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 10,
      "title": "Availability History",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "1 = site available, 0 = site unavailable. Blue shaded regions are scheduled maintenance windows (excluded from SLA discussions).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 11,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "title": "Availability (login probe success)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "probe_success{job=\"glerp-sites-login\", site=\"$site\"}",
          "legendFormat": "$site",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 20,
      "title": "Outage Timeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Visual timeline of up/down periods. Blue shaded regions are scheduled maintenance windows.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP",   "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "id": 21,
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "fillOpacity": 90,
        "rowHeight": 0.9,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Up / Down Timeline",
      "type": "state-timeline",
      "targets": [
        {
          "expr": "probe_success{job=\"glerp-sites-login\", site=\"$site\"}",
          "legendFormat": "$site",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["glerp", "sla", "customer", "report"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "VictoriaMetrics (GLerp Long-term)",
          "value": "glerp-victoriametrics"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "glerp-victoriametrics" },
        "definition": "label_values(probe_success{job=\"glerp-sites-login\"}, site)",
        "hide": 0,
        "includeAll": false,
        "label": "Site",
        "multi": false,
        "name": "site",
        "options": [],
        "query": {
          "query": "label_values(probe_success{job=\"glerp-sites-login\"}, site)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GLerp — Customer SLA Report",
  "uid": "glerp-customer-sla",
  "version": 1
}
