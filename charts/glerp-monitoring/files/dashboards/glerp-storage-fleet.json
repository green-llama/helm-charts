          "expr": "label_replace(\n  max by (instance, mountpoint)(\n    (1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|devtmpfs|overlay|squashfs|ramfs\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|devtmpfs|overlay|squashfs|ramfs\"}) * 100\n  ),\n  \"node\", \"$1\", \"instance\", \"([^:]+):[0-9]+\"\n)",
          "legendFormat": "{{ node }} {{ mountpoint }}",
          "refId": "A"
        }
      ],
      "title": "Node Filesystem Usage Trend",
      "type": "timeseries"
    }
  ],
